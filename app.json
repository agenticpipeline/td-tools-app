{
  "expo": {
    "name": "TD Tools",
    "slug": "td-tools-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a1929"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.tdtools.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a1929"
      },
      "package": "com.tdtools.app",
      "permissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static",
      "name": "TD Tools",
      "shortName": "TD Tools",
      "description": "AI-powered labor estimation for live events",
      "themeColor": "#0a0f1e",
      "backgroundColor": "#0a0f1e",
      "lang": "en"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
